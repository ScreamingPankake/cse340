<%- include('partials/header') %>
    <main>
        <h1>
            <%= title %>
        </h1>
        <p>Here are a few of our partner organizations:</p>
        <ul>
            <% organizations.forEach(org=> { %>
                <li>
                    <img src="images/<%= org.logofile %>" alt="<%= org.name %> logo">
                    <strong>
                        <a href="/organization/<%= org.organization_id %>"><%= org.name %></a>
                    </strong>: <%= org.email %>
                </li>
            <% }) %>
        </ul>
    </main>
    <%- include('partials/footer') %>