<%- include('partials/header') %>
    <main>
        <h1>
            <%= title %>
        </h1>
        <h2>Upcoming Service Projects</h2>
            
        <ul>
        <% if (projects && projects.length > 0) { %>
          <% projects.forEach(project => { %>
            <li>
              <%= project.title %> - <%= project.description %>
            </li>
          <% }) %>
        <% } else { %>
          <li>No projects found</li>
        <% } %>
        </ul>
    </main>
    <%- include('partials/footer') %>