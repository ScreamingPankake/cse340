<%- include('partials/header') %>
    <main>
        <h1>Create New Category</h1>

        <% if (errors && errors.length> 0) { %>
            <div class="errors" role="alert" aria-live="assertive">
                <ul>
                    <% errors.forEach(error=> { %>
                        <li>
                            <%= error %>
                        </li>
                        <% }) %>
                </ul>
            </div>
            <% } %>

                <form method="POST" action="/new-category" novalidate>
                    <label for="category_name">Category Name</label>
                    <input id="category_name" name="category_name" type="text"
                        value="<%= category && category.category_name ? category.category_name : '' %>" required
                        maxlength="100" aria-required="true" />
                    <div class="hint">Required. 1-100 characters (server minimum is 3).</div>

                    <button type="submit">Create Category</button>
                </form>

                <p><a href="/categories">Back to Categories</a></p>
    </main>
    <%- include('partials/footer') %>