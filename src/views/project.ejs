<%- include('partials/header') %>
    <main>
        <h1>
            <%= title %>
        </h1>

        <h2>
            <%= project.title %>
        </h2>
        <p><strong>Description:</strong>
            <%= project.description %>
        </p>
        <p><strong>Location:</strong>
            <%= project.location %>
        </p>
        <p><strong>Date:</strong>
            <%= project.date ? new Date(project.date).toLocaleDateString() : 'TBD' %>
        </p>
        <p><strong>Organization:</strong> <a href="/organization/<%= project.organization_id %>">
                <%= project.organization_name %>
            </a></p>

        <% if (currentUser) { %>
            <% if (isVolunteer) { %>
                <p><strong>Status:</strong> You are volunteering for this project.</p>
                <p><a href="/project/<%= project.project_id %>/remove-volunteer">Remove yourself as volunteer</a></p>
                <% } else { %>
                    <p><a href="/project/<%= project.project_id %>/volunteer">Volunteer for this project</a></p>
                    <% } %>
                        <% } %>

                            <h3>Category Tags</h3>
                            <ul>
                                <% if (categories && categories.length> 0) { %>
                                    <% categories.forEach(category=> { %>
                                        <li><a href="/category/<%= category.category_id %>">
                                                <%= category.category_name %>
                                            </a></li>
                                        <% }) %>
                                            <% } else { %>
                                                <li>No categories assigned to this project.</li>
                                                <% } %>
                            </ul>
    </main>
    <%- include('partials/footer') %>