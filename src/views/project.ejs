<%- include('partials/header') %>
    <main>
        <h1>
            <%= title %>
        </h1>

        <h2>
            <%= project.title %>
        </h2>
        <p><strong>Description:</strong>
            <%= project.description %>
        </p>
        <p><strong>Location:</strong>
            <%= project.location %>
        </p>
        <p><strong>Date:</strong>
            <%= project.date ? new Date(project.date).toLocaleDateString() : 'TBD' %>
        </p>
        <p><strong>Organization:</strong> <a href="/organization/<%= project.organization_id %>">
                <%= project.organization_name %>
            </a></p>

        <h3>Category Tags</h3>
        <ul>
            <% if (categories && categories.length> 0) { %>
                <% categories.forEach(category=> { %>
                    <li><a href="/category/<%= category.category_id %>">
                            <%= category.category_name %>
                        </a></li>
                    <% }) %>
                        <% } else { %>
                            <li>No categories assigned to this project.</li>
                            <% } %>
        </ul>

        <div class="volunteer-section">
            <% if (currentUser) { %>
                <% if (isUserVolunteering) { %>
                    <p class="volunteer-status">✓ You are volunteering for this project</p>
                    <form method="POST" action="/project/<%= project.project_id %>/remove-volunteer" style="display: inline;">
                        <button type="submit" class="button button-danger">Remove as Volunteer</button>
                    </form>
                <% } else { %>
                    <form method="POST" action="/project/<%= project.project_id %>/volunteer" style="display: inline;">
                        <button type="submit" class="button">Volunteer for This Project</button>
                    </form>
                <% } %>
            <% } else { %>
                <p><a href="/login">Log in</a> to volunteer for this project.</p>
            <% } %>
        </div>
    </main>
    <%- include('partials/footer') %>