<%- include('partials/header') %>
    <main>
        <h1><%= title %></h1>

        <% if (errors && errors.length > 0) { %>
            <div class="errors" role="alert" aria-live="assertive">
                <ul>
                    <% errors.forEach(error => { %>
                        <li><%= error %></li>
                    <% }) %>
                </ul>
            </div>
        <% } %>

        <form method="POST" action="/register">
            <label for="name">Name</label>
            <input id="name" name="name" type="text" value="<%= formData.name || '' %>" required maxlength="100" aria-required="true" />

            <label for="email">Email</label>
            <input id="email" name="email" type="email" value="<%= formData.email || '' %>" required maxlength="200" aria-required="true" />

            <label for="password">Password</label>
            <input id="password" name="password" type="password" required maxlength="100" aria-required="true" />

            <label for="passwordConfirm">Confirm Password</label>
            <input id="passwordConfirm" name="passwordConfirm" type="password" required maxlength="100" aria-required="true" />

            <button type="submit">Register</button>
        </form>

        <p>Already have an account? <a href="/login">Login</a></p>
    </main>
<%- include('partials/footer') %>