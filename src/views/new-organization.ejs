<%- include('partials/header') %>
    <main>
        <h1>Create New Organization</h1>

        <% if (errors && errors.length > 0) { %>
            <div class="errors" role="alert" aria-live="assertive">
                <ul>
                    <% errors.forEach(error => { %>
                        <li>
                            <%= error %>
                        </li>
                        <% }) %>
                </ul>
            </div>
            <% } %>

                <form method="POST" action="/new-organization" novalidate>
                    <label for="name">Organization Name</label>
                    <input id="name" name="name" type="text"
                        value="<%= organization && organization.name ? organization.name : '' %>" required
                        maxlength="150" aria-required="true" />
                    <div class="hint">Required. 3-150 characters.</div>

                    <label for="description">Organization Description</label>
                    <textarea id="description" name="description" required maxlength="500" aria-required="true"><%= organization && organization.description ? organization.description : '' %></textarea>
                    <div class="hint">Required. Maximum 500 characters.</div>

                    <label for="email">Contact Email</label>
                    <input id="email" name="email" type="email"
                        value="<%= organization && organization.email ? organization.email : '' %>" required
                        aria-required="true" />
                    <div class="hint">Required. Must be a valid email address.</div>

                    <button type="submit">Create Organization</button>
                </form>

                <p><a href="/organizations">Back to Organizations</a></p>
    </main>
    <%- include('partials/footer') %>
